{
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        // "format": "{name} {icon}",
        "format": "{name}",
        "format-icons": {
            "1": "рЯШГ",
            "2": "рЯР±",
            "3": "рЯШ†",
            "4": "рЯ§У",
            "urgent": "пБ™",
            "default": "рЯШЦ"
        }
    },

    "custom/spacer": {
        "format": " ",
        "min-length": 1,
        "max-length": 1
    },

    "custom/emacs": {
        // "format": "ќµ",
        // "format": "оШ≤",
        "format": "вЬПпЄП",
        "on-click": "emacs",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/krita": {
        "format": "рЯО®",
        "on-click": "krita",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/browser": {
        "format": "рЯМО",
        // "format": "рЯМР",
        // "format": "пВђ",
        // "on-click": "flatpak run com.microsoft.Edge",
        "on-click": "firefox",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/files": {
        "format": "рЯЧВпЄП",
        // "format": "пДФ",
        "on-click": "thunar ~/DCIM/Camera",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/terminal": {
        // "format": "вЧЉпЄП",
        "format": "рЯТї",
        "on-click": "gnome-terminal",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/toolbar/undo": {
        "format": "пДТ",
        "on-click": "exec ydotool key 29:1 44:1 29:0 44:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/toolbar/redo": {
        "format": "пБ§",
        "on-click": "exec ydotool key 29:1 21:1 29:0 21:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/appmenu": {
        "format": "рЯЧДпЄП",
        "on-click": "rofi -show drun -l 10",
        "tooltip": false
    },

    "custom/exit": {
        "format": "в≠Х",
        "on-click": "powermenu.sh",
        "tooltip": false
    },

    "custom/power": {
        "format":"вППпЄП",
        "on-click": "nwg-bar",
        "tooltip": false,
        "min-length": 1,
        "max-length": 3,
    },

    "custom/launcher": {
    	  "format":"рЯЪАпЄП",
    	  "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    	  "tooltip": false,
        "min-length": 2,
        "max-length": 4
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "min-length": 1,
        "max-length": 6
    },

    "clock#date": {
        "format": "{:%b %d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    },
    "clock#time": {
        "format": "{:%H:%M}",
        "tooltip": false,
    },

    "cpu": {
        "format": "{usage}%",
        "tooltip": false,
        "interval": 1,
        "min-length": 1,
        "max-length": 6,
    },

    "memory": {
        "format": "{used:0.1f}G",
        "interval": 2,
        "min-length": 1,
        "max-length": 10,
    },

    "temperature": {
        // "thermal-zone": 2,
        //"hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
        "critical-threshold": 90,
        // "format-critical": "{temperatureC}¬∞C {icon}",
        // "format": "{temperatureC}¬∞C {icon}",
        "format": "{icon} {temperatureC}",
        // "format-icons": ["вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЭД", "вЫЕ", "вЫЕ", "вЫЕ", "рЯМЮ", "рЯМЮ", "рЯМЮ", "рЯФ•"],
        "format-icons": ["вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЭДпЄП", "вЫЕ", "вЫЕ", "вЫЕ", "рЯМЮ", "рЯМЮ", "рЯМЮ", "рЯФ•"],
        "min-length": 4,
        "max-length": 10,
        "interval" : 4
    },

    "custom/keyboard": {
	     "format": "рЯОє",
        "min-length": 1,
        "max-length": 15,
	     "interval": 10,
	     "on-click": "toggle_wlr_keyboard.sh",
    },

    "battery": {
        "interval": 1,
        "states": {
            "good": 95,
            "warning": 12,
            "critical": 6
        },
        "format-icons": {
            "charging": ["пЗ¶  пЙД", "пЗ¶  пЙГ", "пЗ¶  пЙГ", "пЗ¶  пЙГ", "пЗ¶  пЙВ", "пЗ¶  пЙВ", "пЗ¶  пЙБ", "пЗ¶  пЙБ", "пЗ¶  пЙБ", "пЗ¶  пЙА"],
            "default": ["пЙД", "пЙГ", "пЙГ", "пЙГ", "пЙВ", "пЙВ", "пЙБ", "пЙБ", "пЙБ", "пЙА"],
        },
        "format": "{icon} {capacity}",
        "format-charging": "{capacity} рЯФМ",
        "format-plugged": "{capacity} рЯФМ",
        "format-alt": "{time} {icon} ",
        "format-full": "пЙА",
        "min-length": 3,
        "max-length": 30,
        // "align": 2,
    },

    "pulseaudio": {
        "scroll-step": 0.2,
        "format": "{icon} {volume}",
        "format-muted": "рЯФЗ {format_source}",
        "format-source": "пД∞% {volume}",
        "format-source-muted": "пД±",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["рЯФК"]
        },
        "on-click": "pavucontrol",
        "min-length": 1,
        "max-length": 6
    },

    "user": {
        "format": "{user}",
        "interval": 60,
        "height": 30,
        "width": 30,
        "icon": false,
    },

    "backlight": {
        "scroll-step": 8,
        "format": "{icon} {percent}",
        "format-icons": ["вШАпЄП"],
        "min-length": 1,
        "max-length": 6
    },

    "sway/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "hyprland/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "network": {
        "format-wifi": "пЗЂ {essid}",
        "format-disconnected": "пЗЂ Disconnected",
        "format-disabled": "пЗЂ Disabled",
        "interval": 5,
        "min-length": 1,
        "max-length": 6
    },

    "idle_inhibitor": {
	     "format": "{icon}",
	     "format-icons": {
		      "activated": "рЯСА",
		      "deactivated": "рЯМЬ"
	     },
        "min-length": 2,
        "max-length": 4,
	     "timeout": 6000.0,
    },

    "custom/recorder": {
        // "format": "пАљ ",
        "on-click": "screen-record.sh",
        "return-type": "json",
        "interval": 1,
        "exec": "screen-record-check-status.sh",
        "min-length": 1,
        "max-length": 6,
    },

    "custom/screenshot": {
        // "format": "рЯОђ",
        "format": "рЯУЄ",
        "on-click": "screenshot_wayland.sh",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/caps_lock": {
        "exec": "led-monitor.sh --caps",
        "interval": 1,
        "return-type": "json"
    },
    "custom/num_lock": {
        "exec": "led-monitor.sh --num",
        "interval": 1,
        "return-type": "json"
    },
    "custom/scroll_lock": {
        "exec": "led-monitor.sh --scroll",
        "interval": 1,
        "return-type": "json"
    },

    "custom/togglesticky": {
        "exec": "keymap-monitor.sh",
        "interval": 1,
        "return-type": "json",
        "on-click": "keymap-toggle.sh",
    }
}
