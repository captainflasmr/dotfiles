{
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        // "format": "{name} {icon}",
        "format": "{name}",
        "format-icons": {
            "1": "рҹҳғ",
            "2": "рҹҗұ",
            "3": "рҹҳ ",
            "4": "рҹӨ“",
            "urgent": "пҒӘ",
            "default": "рҹҳ–"
        }
    },

    "custom/spacer": {
        "format": " ",
        "min-length": 1,
        "max-length": 1
    },

    "custom/emacs": {
        // "format": "Оө",
        // "format": "оҳІ",
        "format": "вңҸпёҸ",
        "on-click": "emacs",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/krita": {
        "format": "рҹҺЁ",
        "on-click": "krita",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/browser": {
        "format": "рҹҢҺ",
        // "format": "рҹҢҗ",
        // "format": "пӮ¬",
        // "on-click": "flatpak run com.microsoft.Edge",
        "on-click": "firefox",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/files": {
        "format": "рҹ—ӮпёҸ",
        // "format": "п„”",
        "on-click": "thunar ~/DCIM/Camera",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/terminal": {
        // "format": "в—јпёҸ",
        "format": "рҹ’»",
        "on-click": "gnome-terminal",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/toolbar/undo": {
        "format": "п„’",
        "on-click": "exec ydotool key 29:1 44:1 29:0 44:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/toolbar/redo": {
        "format": "пҒӨ",
        "on-click": "exec ydotool key 29:1 21:1 29:0 21:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/appmenu": {
        "format": "рҹ—„пёҸ",
        "on-click": "rofi -show drun -l 10",
        "tooltip": false
    },

    "custom/exit": {
        "format": "вӯ•",
        "on-click": "powermenu.sh",
        "tooltip": false
    },

    "custom/power": {
        "format":"вҸҸпёҸ",
        "on-click": "nwg-bar",
        "tooltip": false,
        "min-length": 1,
        "max-length": 3,
    },

    "custom/launcher": {
    	  "format":"рҹҡҖпёҸ",
    	  "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    	  "tooltip": false,
        "min-length": 2,
        "max-length": 4
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "min-length": 1,
        "max-length": 6
    },

    "clock#date": {
        "format": "{:%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    },
    "clock#time": {
        "format": "{:%H:%M}",
        "tooltip": false,
    },

    "cpu": {
        "format": "{usage}%",
        "tooltip": false,
        "interval": 1,
        "min-length": 1,
        "max-length": 6,
    },

    "memory": {
        "format": "{used:0.1f}G",
        "interval": 2,
        "min-length": 1,
        "max-length": 10,
    },

    "temperature": {
        // "thermal-zone": 2,
        //"hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
        "critical-threshold": 90,
        // "format-critical": "{temperatureC}В°C {icon}",
        // "format": "{temperatureC}В°C {icon}",
        "format": "{icon} {temperatureC}",
        // "format-icons": ["вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вӣ…", "вӣ…", "вӣ…", "рҹҢһ", "рҹҢһ", "рҹҢһ", "рҹ”Ҙ"],
        "format-icons": ["вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вқ„пёҸ", "вӣ…", "вӣ…", "вӣ…", "рҹҢһ", "рҹҢһ", "рҹҢһ", "рҹ”Ҙ"],
        "min-length": 4,
        "max-length": 10,
        "interval" : 4
    },

    "custom/keyboard": {
	     "format": "рҹҺ№",
        "min-length": 1,
        "max-length": 15,
	     "interval": 10,
	     "on-click": "toggle_wlr_keyboard.sh",
    },

    "battery": {
        "interval": 1,
        "states": {
            "good": 95,
            "warning": 12,
            "critical": 6
        },
        "format-icons": {
            "charging": ["пҮҰ  пү„", "пҮҰ  пүғ", "пҮҰ  пүғ", "пҮҰ  пүғ", "пҮҰ  пүӮ", "пҮҰ  пүӮ", "пҮҰ  пүҒ", "пҮҰ  пүҒ", "пҮҰ  пүҒ", "пҮҰ  пүҖ"],
            "default": ["пү„", "пүғ", "пүғ", "пүғ", "пүӮ", "пүӮ", "пүҒ", "пүҒ", "пүҒ", "пүҖ"],
        },
        "format": "{icon} {capacity}",
        "format-charging": "{capacity} рҹ”Ң",
        "format-plugged": "{capacity} рҹ”Ң",
        "format-alt": "{time} {icon} ",
        "format-full": "пүҖ",
        "min-length": 3,
        "max-length": 30,
        // "align": 2,
    },

    "pulseaudio": {
        "scroll-step": 0.2,
        "format": "{icon} {volume}",
        "format-muted": "рҹ”Ү {format_source}",
        "format-source": "п„°% {volume}",
        "format-source-muted": "п„ұ",
        "format-icons": {
            "headphone": "пҖҘ",
            "hands-free": "п–җ",
            "headset": "п–җ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": ["рҹ”Ҡ"]
        },
        "on-click": "pavucontrol",
        "min-length": 1,
        "max-length": 6
    },

    "user": {
        "format": "{user}",
        "interval": 60,
        "height": 30,
        "width": 30,
        "icon": false,
    },

    "backlight": {
        "scroll-step": 0.5,
        "format": "{icon} {percent}",
        "format-icons": ["вҳҖпёҸ"],
        "min-length": 1,
        "max-length": 6
    },

    "sway/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "hyprland/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "network": {
        "format-wifi": "пҮ« {essid}",
        "format-disconnected": "пҮ« Disconnected",
        "format-disabled": "пҮ« Disabled",
        "interval": 5,
        "min-length": 1,
        "max-length": 6
    },

    "custom/idle_inhibitor": {
        "exec": "~/.config/waybar/scripts/idle_status.sh",
        "return-type": "json",
        "format": "{}",
        "signal": 1,
        "interval": 2,
        "on-click": "~/.config/sway/scripts/toggle_idle.sh",
        "tooltip": true
    },

    "custom/recorder": {
        // "format": "пҖҪ ",
        "on-click": "screen-record.sh",
        "return-type": "json",
        "interval": 1,
        "exec": "screen-record-check-status.sh",
        "min-length": 1,
        "max-length": 6,
    },

    "custom/screenshot": {
        // "format": "рҹҺ¬",
        "format": "рҹ“ё",
        "on-click": "screenshot_wayland.sh",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/caps_lock": {
        "exec": "led-monitor.sh --caps",
        "interval": 1,
        "return-type": "json"
    },
    "custom/num_lock": {
        "exec": "led-monitor.sh --num",
        "interval": 1,
        "return-type": "json"
    },
    "custom/scroll_lock": {
        "exec": "led-monitor.sh --scroll",
        "interval": 1,
        "return-type": "json"
    },

    "custom/togglesticky": {
        "exec": "keymap-monitor.sh",
        "interval": 1,
        "return-type": "json",
        "on-click": "keymap-toggle.sh",
    }
}
