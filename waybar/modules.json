{
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        // "format": "{name} {icon}",
        "format": "{name}",
        "format-icons": {
            "1": "ЁЯШГ",
            "2": "ЁЯР▒",
            "3": "ЁЯШа",
            "4": "ЁЯдУ",
            "urgent": "яБк",
            "default": "ЁЯШЦ"
        }
    },

    "custom/spacer": {
        "format": " ",
        "min-length": 1,
        "max-length": 1
    },

    "custom/emacs": {
        // "format": "╬╡",
        "format": "юШ▓",
        // "format": "ЁЯС╛",
        // "format": "ЁЯФо",
        // "format": "ЁЯЯг",
        "on-click": "emacs",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/browser": {
        // "format": "ЁЯМО",
        // "format": "ЁЯМР",
        "format": "яВм",
        // "on-click": "flatpak run com.microsoft.Edge",
        "on-click": "firefox",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/files": {
        // "format": "ЁЯЧВя╕П",
        "format": "яДФ",
        "on-click": "thunar ~/DCIM/Camera",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/terminal": {
        // "format": "ЁЯЦея╕П",
        "format": "юпЗ",
        // "format": "яЛР",
        "on-click": "gnome-terminal",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/toolbar/undo": {
        "format": "яДТ",
        "on-click": "exec ydotool key 29:1 44:1 29:0 44:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/toolbar/redo": {
        "format": "яБд",
        "on-click": "exec ydotool key 29:1 21:1 29:0 21:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/appmenu": {
        "format": "ЁЯЧДя╕П",
        "on-click": "rofi -show drun -l 10",
        "tooltip": false
    },

    "custom/exit": {
        "format": "тнХ",
        "on-click": "powermenu.sh",
        "tooltip": false
    },

    "custom/power": {
        "format":"тП╗ ",
        "on-click": "nwg-bar",
        "tooltip": false,
        "min-length": 1,
        "max-length": 3,
    },

    "custom/launcher": {
    	  "format":"яД╡",
    	  "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    	  "tooltip": false,
        "min-length": 2,
        "max-length": 4
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "min-length": 1,
        "max-length": 6
    },

    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d %H:%M}",
        "format": "{:%H:%M}",
        "min-length": 1,
        "max-length": 18,
    },

    "cpu": {
        "format": " {usage}%",
        "tooltip": false,
        "interval": 1,
        "min-length": 1,
        "max-length": 6,
    },

    "memory": {
        "format": "{used:0.1f}G",
        "interval": 2,
        "min-length": 1,
        "max-length": 10,
    },

    "temperature": {
        // "thermal-zone": 2,
        //"hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
        "critical-threshold": 90,
        // "format-critical": "{temperatureC}┬░C {icon}",
        // "format": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC} {icon}",
        "format-icons": ["тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЭД", "тЫЕ", "тЫЕ", "тЫЕ", "ЁЯМЮ", "ЁЯМЮ", "ЁЯМЮ", "ЁЯФе"],
        "min-length": 4,
        "max-length": 10,
        "interval" : 4,
    },

    "custom/keyboard": {
	     "format": "яДЬ ",
        "min-length": 1,
        "max-length": 15,
	     "interval": 10,
	     "on-click": "toggle_wlr_keyboard.sh",
    },

    "battery": {
        "interval": 2,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 6
        },
        "format-icons": {
            "charging": ["яЗж  яЙД", "яЗж  яЙГ", "яЗж  яЙВ", "яЗж  яЙБ", "яЗж  яЙА"],
            "default": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        },
        "format": "{capacity}% {icon} ",
        "format-charging": " яЗж {capacity} ",
        "format-plugged": " яЗж {capacity} ",
        "format-alt": "{time} {icon} ",
        "format-full": "яЙА",
        "min-length": 3,
        "max-length": 30,
        // "align": 2,
    },

    "pulseaudio": {
        "scroll-step": 0.1,
        "format": "{volume} {icon}",
        "format-muted": "ЁЯФЗ {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАи", "яАи"]
        },
        "on-click": "pavucontrol",
        "min-length": 1,
        "max-length": 6
    },

    "user": {
        "format": "{user}",
        "interval": 60,
        "height": 30,
        "width": 30,
        "icon": false,
    },

    "backlight": {
        "scroll-step": 8,
        "format": "{percent} ЁЯФЕ",
        "min-length": 1,
        "max-length": 6
    },

    "sway/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "hyprland/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "network": {
        "format-wifi": "яЗл {essid}",
        "format-disconnected": "яЗл Disconnected",
        "format-disabled": "яЗл Disabled",
        "interval": 5,
        "min-length": 1,
        "max-length": 6
    },

    "idle_inhibitor": {
	     "format": "{icon}",
	     "format-icons": {
		      "activated": "яБо",
		      "deactivated": "яБ░"
	     },
        "min-length": 3,
        "max-length": 6,
	     "timeout": 600.0,
    },

    "custom/recorder": {
        "format": "яА╜",
        "on-click": "screen-record.sh",
        "return-type": "json",
        "interval": 1,
        "exec": "if pgrep \"^wf-recorder$\" >/dev/null; then echo '{\"class\": \"recording\"}'; else echo '{\"class\": \"ready\"}'; fi",
        "min-length": 1,
        "max-length": 4

        // "exec-if": "pgrep wf-recorder"
    },

    "custom/screenshot": {
        // "format": "ЁЯУ╖",
        "format": "ґ░ДА",
        "on-click": "screenshot_wayland_001.sh",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    }
}
