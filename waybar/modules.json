{
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        // "format": "{name} {icon}",
        "format": "{name}",
        "format-icons": {
            "1": "ΏθαΔ",
            "2": "ΏθΡ▒",
            "3": "Ώθαι",
            "4": "ΏθνΥ",
            "urgent": "ΎΒς",
            "default": "ΏθαΨ"
        }
    },

    "custom/spacer": {
        "format": " ",
        "min-length": 1,
        "max-length": 1
    },

    "custom/emacs": {
        // "format": "╬╡",
        "format": "Όα▓",
        // "format": "ΏθΣ╛",
        // "format": "ΏθΦχ",
        // "format": "Ώθθμ",
        "on-click": "emacs",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/browser": {
        // "format": "ΏθΝΟ",
        // "format": "ΏθΝΡ",
        "format": "ΎΓυ",
        // "on-click": "flatpak run com.microsoft.Edge",
        "on-click": "firefox",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/files": {
        // "format": "ΏθΩΓΎ╕Π",
        "format": "ΎΕΦ",
        "on-click": "thunar ~/DCIM/Camera",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/terminal": {
        // "format": "ΏθΨξΎ╕Π",
        "format": "ΌψΘ",
        // "format": "ΎΜΡ",
        "on-click": "gnome-terminal",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    },

    "custom/toolbar/undo": {
        "format": "ΎΕΤ",
        "on-click": "exec ydotool key 29:1 44:1 29:0 44:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/toolbar/redo": {
        "format": "ΎΒν",
        "on-click": "exec ydotool key 29:1 21:1 29:0 21:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/appmenu": {
        "format": "ΏθΩΕΎ╕Π",
        "on-click": "rofi -show drun -l 10",
        "tooltip": false
    },

    "custom/exit": {
        "format": "έφΧ",
        "on-click": "powermenu.sh",
        "tooltip": false
    },

    "custom/power": {
        "format":"έΠ╗ ",
        "on-click": "nwg-bar",
        "tooltip": false,
        "min-length": 1,
        "max-length": 3,
    },

    "custom/launcher": {
    	  "format":"ΎΕ╡",
    	  "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    	  "tooltip": false,
        "min-length": 2,
        "max-length": 4
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "min-length": 1,
        "max-length": 6
    },

    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d %H:%M}",
        "format": "{:%H:%M}",
        "min-length": 1,
        "max-length": 18,
    },

    "cpu": {
        "format": " {usage}%",
        "tooltip": false,
        "interval": 1,
        "min-length": 1,
        "max-length": 6,
    },

    "memory": {
        "format": "{used:0.1f}G",
        "interval": 2,
        "min-length": 1,
        "max-length": 10,
    },

    "temperature": {
        // "thermal-zone": 2,
        //"hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
        "critical-threshold": 90,
        // "format-critical": "{temperatureC}┬░C {icon}",
        // "format": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC} {icon}",
        "format-icons": ["έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έζΕ", "έδΖ", "έδΖ", "έδΖ", "ΏθΝη", "ΏθΝη", "ΏθΝη", "ΏθΦξ"],
        "min-length": 4,
        "max-length": 10,
        "interval" : 4,
    },

    "custom/keyboard": {
	     "format": "ΎΕε ",
        "min-length": 1,
        "max-length": 15,
	     "interval": 10,
	     "on-click": "toggle_wlr_keyboard.sh",
    },

    "battery": {
        "interval": 2,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 6
        },
        "format-icons": {
            "charging": ["ΎΘο  ΎΚΕ", "ΎΘο  ΎΚΔ", "ΎΘο  ΎΚΔ", "ΎΘο  ΎΚΔ", "ΎΘο  ΎΚΓ", "ΎΘο  ΎΚΓ", "ΎΘο  ΎΚΒ", "ΎΘο  ΎΚΒ", "ΎΘο  ΎΚΒ", "ΎΘο  ΎΚΑ"],
            "default": ["ΎΚΕ", "ΎΚΔ", "ΎΚΔ", "ΎΚΔ", "ΎΚΓ", "ΎΚΓ", "ΎΚΒ", "ΎΚΒ", "ΎΚΒ", "ΎΚΑ"],
        },
        "format": "{capacity}% {icon} ",
        "format-charging": " ΎΘο {capacity} ",
        "format-plugged": " ΎΘο {capacity} ",
        "format-alt": "{time} {icon} ",
        "format-full": "ΎΚΑ",
        "min-length": 3,
        "max-length": 30,
        // "align": 2,
    },

    "pulseaudio": {
        "scroll-step": 0.1,
        "format": "{volume} {icon}",
        "format-muted": "ΏθΦΘ {format_source}",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑρ", "ΎΑρ"]
        },
        "on-click": "pavucontrol",
        "min-length": 1,
        "max-length": 6
    },

    "user": {
        "format": "{user}",
        "interval": 60,
        "height": 30,
        "width": 30,
        "icon": false,
    },

    "backlight": {
        "scroll-step": 8,
        "format": "{percent} ΏθΦΖ",
        "min-length": 1,
        "max-length": 6
    },

    "sway/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "hyprland/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "network": {
        "format-wifi": "ΎΘτ {essid}",
        "format-disconnected": "ΎΘτ Disconnected",
        "format-disabled": "ΎΘτ Disabled",
        "interval": 5,
        "min-length": 1,
        "max-length": 6
    },

    "idle_inhibitor": {
	     "format": "{icon}",
	     "format-icons": {
		      "activated": "ΎΒχ",
		      "deactivated": "ΎΒ░"
	     },
        "min-length": 3,
        "max-length": 6,
	     "timeout": 600.0,
    },

    "custom/recorder": {
        "format": "ΎΑ╜",
        "on-click": "screen-record.sh",
        "return-type": "json",
        "interval": 1,
        "exec": "if pgrep \"^wf-recorder$\" >/dev/null; then echo '{\"class\": \"recording\"}'; else echo '{\"class\": \"ready\"}'; fi",
        "min-length": 1,
        "max-length": 4

        // "exec-if": "pgrep wf-recorder"
    },

    "custom/screenshot": {
        // "format": "ΏθΥ╖",
        "format": "≤░ΕΑ",
        "on-click": "screenshot_wayland_001.sh",
        "min-length": 2,
        "max-length": 2,
        "tooltip": false
    }
}
