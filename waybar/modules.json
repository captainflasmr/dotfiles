{
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name} {icon}",
        "format-icons": {
            "1": "рҹҳғ",
            "2": "рҹҗұ",
            "3": "рҹҳ ",
            "4": "рҹӨ“",
            "urgent": "пҒӘ",
            "default": "рҹҳ–"
        }
    },

    "custom/spacer": {
        "format": " ",
        "min-length": 1,
        "max-length": 1
    },

    "custom/browser": {
        // "format": "рҹҢҗ",
        "format": "пӮ¬",
        "on-click": "flatpak run com.microsoft.Edge",
        "tooltip": false
    },

    "custom/files": {
        // "format": "рҹ—ӮпёҸ",
        "format": "п„”",
        "on-click": "thunar ~/DCIM/Camera",
        "tooltip": false
    },

    "custom/terminal": {
        // "format": "рҹ–ҘпёҸ",
        "format": "пӢҗ",
        "on-click": "gnome-terminal",
        "tooltip": false
    },

    "custom/toolbar/undo": {
        "format": "п„’",
        "on-click": "exec ydotool key 29:1 44:1 29:0 44:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/toolbar/redo": {
        "format": "пҒӨ",
        "on-click": "exec ydotool key 29:1 21:1 29:0 21:0",
        "tooltip": false,
        "min-length": 2,
        "max-length": 2
    },

    "custom/appmenu": {
        "format": "рҹ—„пёҸ",
        "on-click": "rofi -show drun -l 10",
        "tooltip": false
    },

    "custom/exit": {
        "format": "вӯ•",
        "on-click": "powermenu.sh",
        "tooltip": false
    },

    "custom/power": {
        "format":"вҸ»",
        "on-click": "nwg-bar",
        "tooltip": false,
        "min-length": 1,
        "max-length": 1,
    },

    "custom/launcher": {
    	  "format":"п„ө",
    	  "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    	  "tooltip": false,
        "min-length": 1,
        "max-length": 4
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "min-length": 1,
        "max-length": 6
    },

    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d %H:%M}",
        "format": "{:%H:%M}",
        "min-length": 1,
        "max-length": 18,
    },

    "cpu": {
        "format": "{usage}%",
        "tooltip": false,
        "interval": 1,
        "min-length": 3,
        "max-length": 6,
    },

    "memory": {
        "format": "{used:0.1f}G",
        "interval": 2,
        "min-length": 1,
        "max-length": 8,
    },

    "temperature": {
        // "thermal-zone": 2,
        //"hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
        "critical-threshold": 90,
        // "format-critical": "{temperatureC}В°C {icon}",
        // "format": "{temperatureC}В°C {icon}",
        "format": "{temperatureC} {icon}",
        "format-icons": ["вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вқ„", "вӣ…", "вӣ…", "вӣ…", "рҹҢһ", "рҹҢһ", "рҹҢһ", "рҹ”Ҙ"],
        "min-length": 1,
        "max-length": 10,
        "interval" : 4,
    },

    "custom/keyboard": {
	     "format": "п„ң ",
        "min-length": 1,
        "max-length": 15,
	     "interval": 10,
	     "on-click": "toggle_wlr_keyboard.sh",
    },

    "battery": {
        "interval": 2,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 6
        },
        "format-icons": {
            "charging": ["пҮҰ  пү„", "пҮҰ  пүғ", "пҮҰ  пүӮ", "пҮҰ  пүҒ", "пҮҰ  пүҖ"],
            "default": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"],
        },
        "format": "{capacity} {icon}",
        "format-charging": "{capacity} пҮҰ ",
        "format-plugged": "{capacity} пҮҰ ",
        "format-alt": "{time} {icon}",
        "format-full": "пүҖ",
        "min-length": 6,
        "max-length": 20,
    },

    "pulseaudio": {
        "scroll-step": 0.1,
        "format": "{volume} {icon}",
        "format-bluetooth": "{volume}% {icon}пҠ” {format_source}",
        "format-bluetooth-muted": "пҡ© {icon}пҠ” {format_source}",
        "format-muted": "пҡ© {format_source}",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„ұ",
        "format-icons": {
            "headphone": "пҖҘ",
            "hands-free": "п–җ",
            "headset": "п–җ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": ["пҖҰ", "пҖЁ ", "пҖЁ "]
        },
        "on-click": "pavucontrol"
    },

    "user": {
        "format": "{user}",
        "interval": 60,
        "height": 30,
        "width": 30,
        "icon": false,
    },

    "backlight": {
        "scroll-step": 10,
        "format": "{percent} рҹ”…",
        "min-length": 1,
        "max-length": 8,
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    },

    "sway/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "hyprland/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "network": {
        "format-wifi": "пҮ« {essid}",
        "format-disconnected": "пҮ« Disconnected",
        "format-disabled": "пҮ« Disabled",
        "interval": 5,
        "min-length": 1,
        "max-length": 6
    },

    "idle_inhibitor": {
	     "format": "{icon} ",
	     "format-icons": {
		      "activated": "пҒ®",
		      "deactivated": "пҒ°"
	     },
        "min-length": 2,
        "max-length": 6,
	     "timeout": 30.5,
    }
}
