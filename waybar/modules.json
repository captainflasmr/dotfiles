{
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name} {icon}",
        "format-icons": {
            "1": "😃",
            "2": "🐱",
            "3": "😠",
            "4": "🤓",
            "urgent": "",
            "default": "😖"
        }
    },

    "custom/browser": {
        "format": "🌐",
        "on-click": "flatpak run com.microsoft.Edge",
        "tooltip": false
    },

    "custom/files": {
        "format": "🗂️",
        "on-click": "thunar ~/DCIM/Camera",
        "tooltip": false
    },

    "custom/terminal": {
        "format": "🖥️",
        "on-click": "gnome-terminal",
        "tooltip": false
    },

    "custom/appmenu": {
        "format": "🗄️",
        "on-click": "rofi -show drun -l 10",
        "tooltip": false
    },

    "custom/exit": {
        "format": "⭕",
        "on-click": "powermenu.sh",
        "tooltip": false
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10
    },

    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%Y-%m-%d %H:%M}",
        "format-alt": "{:%Y-%m-%d}",
        "min-length": 10,
        "max-length": 18,
    },

    "cpu": {
        "format": "{usage}%",
        "tooltip": false,
        "interval": 1,
        "min-length": 4,
        "max-length": 6,
        "align" : 1,
    },

    "memory": {
        "format": "{used:0.1f} GiB",
        "interval": 2,
        "min-length": 8,
        "max-length": 8,
    },

    "temperature": {
        // "thermal-zone": 2,
        //"hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
        "critical-threshold": 90,
        // "format-critical": "{temperatureC}°C {icon}",
        "format": "{temperatureC}°C {icon}",
        "format-icons": ["❄", "❄", "❄", "❄", "❄", "❄", "❄", "❄", "❄", "❄", "❄", "❄", "❄", "⛅", "⛅", "⛅", "🌞", "🌞", "🌞", "🔥"],
        "min-length": 1,
        "max-length": 10,
        "interval" : 4,
    },

    "custom/keyboard": {
	     "format": "{}",
        "min-length": 1,
        "max-length": 15,
	     "interval": 10,
	     "exec": "echo ''",
	     "on-click": "toggle_wlr_keyboard.sh",
    },

    "battery": {
        "interval": 10,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 6
        },
        "format-icons": {
            "charging": ["   ", "   ", "   ", "   ", "   "],
            "default": ["", "", "", "", ""],
        },
        "format": "{capacity}% {icon}",
        "Format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        "format-full": "",
        "min-length": 7,
        "max-length": 11,
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": " {volume}% {icon}",
        "format-bluetooth": "{volume}% {icon} {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": " {format_source}",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", " ", " "]
        },
        "on-click": "pavucontrol"
    },

    "user": {
        "format": "{user}",
        "interval": 60,
        "height": 30,
        "width": 30,
        "icon": false,
    },

    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% 🔅",
        "min-length": 1,
        "max-length": 8,
        "format-icons": ["", "", "", "", "", "", "", "", ""]
    },

    "sway/window": {
        "min-length": 1,
        "max-length": 50,
    },

    "hyprland/window": {
        "min-length": 1,
        "max-length": 60,
    },

    "network": {
        "format-wifi": " {essid}",
        "format-disconnected": " Disconnected",
        "format-disabled": " Disabled",
        "interval": 5,
        "min-length": 1,
        "max-length": 6
    }
}
