{
    "$schema": "https://opencode.ai/config.json",
    "model": "opencode-go/deepseek-v4-flash",
    "default_agent": "deepseek-flash",
    "snapshot": false,
    "agent": {
        "deepseek-flash": {
            "description": "Primary agent. Fast, cheap orchestration for routine engineering work.",
            "mode": "primary",
            "model": "opencode-go/deepseek-v4-flash",
            "steps": 30
        },
        "glm-advisor": {
            "description": "Strategic advisor for second opinions, plan critique, and architecture tradeoffs.",
            "mode": "subagent",
            "hidden": false,
            "model": "opencode-go/glm-5.2",
            "steps": 15,
            "temperature": 0.3,
            "reasoningEffort": "high",
            "prompt": "{file:prompts/glm-advisor.md}",
            "permission": {
                "read": "allow",
                "glob": "allow",
                "grep": "allow",
                "list": "allow",
                "webfetch": "allow",
                "edit": "deny",
                "write": "deny",
                "bash": "deny",
                "task": "deny",
                "question": "allow",
                "todowrite": "deny"
            }
        }
    },
    "provider": {
        "ollama": {
            "models": {
                "gemma4:26b": {
                    "_launch": true,
                    "name": "gemma4:26b"
                },
                "gemma4:31b-cloud": {
                    "_launch": true,
                    "name": "gemma4:31b-cloud"
                },
                "gemini-3-flash-preview:cloud": {
                    "_launch": true,
                    "name": "gemini-3-flash-preview:cloud"
                },
                "deepseek-v3.1:671b-cloud": {
                    "_launch": true,
                    "name": "deepseek-v3.1:671b-cloud"
                },
                "deepseek-v3.2:cloud": {
                    "_launch": true,
                    "name": "deepseek-v3.2:cloud"
                },
                "deepseek-v4-flash:cloud": {
                    "_launch": true,
                    "name": "deepseek-v4-flash:cloud"
                },
                "deepseek-v4-pro:cloud": {
                    "_launch": true,
                    "name": "deepseek-v4-pro:cloud"
                },
                "glm-4.7:cloud": {
                    "_launch": true,
                    "name": "glm-4.7:cloud"
                },
                "glm-5:cloud": {
                    "_launch": true,
                    "name": "glm-5:cloud"
                },
                "glm-5.1:cloud": {
                    "_launch": true,
                    "name": "glm-5.1:cloud"
                },
                "glm-5.2:cloud": {
                    "_launch": true,
                    "name": "glm-5.2:cloud"
                },
                "gpt-oss:120b-cloud": {
                    "_launch": true,
                    "name": "gpt-oss:120b-cloud"
                },
                "gpt-oss:20b-cloud": {
                    "_launch": true,
                    "name": "gpt-oss:20b-cloud"
                },
                "kimi-k2.5:cloud": {
                    "_launch": true,
                    "name": "kimi-k2.5:cloud"
                },
                "kimi-k2.6:cloud": {
                    "_launch": true,
                    "name": "kimi-k2.6:cloud"
                },
                "minimax-m2.1:cloud": {
                    "_launch": true,
                    "name": "minimax-m2.1:cloud"
                },
                "minimax-m2.7:cloud": {
                    "_launch": true,
                    "name": "minimax-m2.7:cloud"
                },
                "nemotron-3-super:cloud": {
                    "_launch": true,
                    "name": "nemotron-3-super:cloud"
                },
                "qwen2.5-coder:7b": {
                    "_launch": true,
                    "name": "qwen2.5-coder:7b"
                },
                "qwen3-coder-next:cloud": {
                    "_launch": true,
                    "limit": {
                        "context": 262144,
                        "output": 32768
                    },
                    "name": "qwen3-coder-next:cloud"
                },
                "qwen3-coder:480b-cloud": {
                    "_launch": true,
                    "name": "qwen3-coder:480b-cloud"
                },
                "qwen3-next:80b-cloud": {
                    "_launch": true,
                    "name": "qwen3-next:80b-cloud"
                },
                "qwen3.5:4b": {
                    "_launch": true,
                    "name": "qwen3.5:4b"
                },
                "qwen3.5:cloud": {
                    "_launch": true,
                    "name": "qwen3.5:cloud"
                },
                "tinyllama:latest": {
                    "_launch": true,
                    "name": "tinyllama:latest"
                }
            },
            "name": "Ollama",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://127.0.0.1:11434/v1"
            }
        }
    }
}
