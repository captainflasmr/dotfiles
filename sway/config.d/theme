# Apply gtk theming
exec_always ~/.config/sway/scripts/import-gsettings

# Set inner/outer gaps (outer 0 so waybar sits flush with windows)
gaps inner 5
gaps outer 0

# Hide titlebar on windows:
default_border pixel 2

# Default Font
font pango:Noto Sans Regular 10

# Thin borders:
smart_borders on

# Title format for windows
for_window [shell="xdg_shell"] title_format "%title (%app_id)"
for_window [shell="x_wayland"] title_format "%class - %title"

## Window decoration — colors from pywal (see ~/.cache/wal/sway)
include ~/.cache/wal/sway

## Override unfocused colours to always be dark grey (pywal keeps focused bright)
# class                 border    backgr.   text      indicator child_border
client.unfocused        #555555   #222222   #777777   #555555   #555555
client.focused_inactive #666666   #2a2a2a   #888888   #666666   #666666

