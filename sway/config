# config for sway

gaps inner 10px
gaps outer 0px
gaps top -7px
gaps bottom 0px

# class                 border  backgr. text    indicator child_border
client.focused          #000000 #0b4b55 #cccccc #999999   #bbbbbb
client.focused_inactive #333333 #333333 #cccccc #484e50   #5f676a
client.unfocused        #333333 #222222 #cccccc #292d2e   #222222
client.urgent           #2f343a #900000 #cccccc #900000   #900000
client.placeholder      #000000 #0c0c0c #cccccc #000000   #0c0c0c

client.background       #aaaaaa

for_window [class="Emacs"] opacity 0.92
for_window [class="dolphin"] opacity 0.9
for_window [class="firefox"] opacity 0.99
for_window [class="thunderbird"] opacity 0.9
# for_window [app_id=".*"] opacity $opacity

# startup
exec {
   /home/jdyer/bin/startup.sh
   exec gammastep-indicator
}

default_border pixel 4px

set $mod Mod4

set $left h
set $down j
set $up k
set $right l

set $term alacritty

font pango:SourceCodePro Medium 12

bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +2%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -2%

Bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

# input
input type:touchpad {
    tap enabled
    natural_scroll enabled
    pointer_accel 0.8
}

input type:touch {
    events disabled
}

input type:keyboard {
  xkb_layout gb
  xkb_options caps:ctrl_modifier
}

input "type:tablet_tool" {

}

input "1539:247:SINO_WEALTH_USB_Keyboard" {

}

### Key bindings
#
# Basics:
#
bindsym $mod+Shift+p exec wl-color-picker

bindsym $mod+Shift+w exec styli.sh -y -d ~/wallpaper

# programs
bindsym $mod+Shift+s exec grim -t jpeg -g "$(slurp)" ~/DCIM/Screenshots/$(date +'%Y-%m-%d-%H-%M-%S.jpg')
bindsym $mod+e exec dolphin
bindsym $mod+i exec plasma-open-settings
bindsym $mod+c exec emacs
bindsym $mod+m exec thunderbird
bindsym $mod+w exec firefox
bindsym $mod+s exec pamac-manager
bindsym $mod+p exec keepassxc

# Allow switching between workspaces with left and right swipes
bindgesture swipe:4:left workspace next
bindgesture swipe:4:right workspace prev
# bindgesture swipe:3:left ydotool alt+left
# bindgesture swipe:3:right ydotool alt+right

# Start a terminal
bindsym $mod+Return exec $term
bindsym control+alt+t exec $term

# Kill focused window
bindsym $mod+Shift+q kill
bindsym Alt+F4 kill

# Start your launcher
bindsym alt+space exec wofi --show
bindsym $mod+d exec --no-startup-id dmenu_run

# Drag floating windows by holding down $mod and left mouse button.
# Resize them with right mouse button + $mod.
# Despite the name, also works for non-floating windows.
# Change normal to inverse to use left mouse button for resizing and right
# mouse button for dragging.
floating_modifier $mod normal

# exit
bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'

#
# Moving around:
#
# Move your focus around
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym control+alt+o focus left
# Or use $mod+[up|down|left|right]
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move the focused window with the same, but add Shift
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
# Ditto, with arrow keys
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

#
# Workspaces:
#
# Switch to workspace
bindsym control+alt+l workspace next
bindsym control+alt+h workspace prev

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
Bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10
# Move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

bindsym $mod+f fullscreen

# Toggle the current focus between tiling and floating mode
bindsym $mod+Shift+space floating toggle

# Swap focus between the tiling area and the floating area
bindsym $mod+space focus mode_toggle

# Move focus to the parent container
bindsym $mod+a focus parent

# Reload the configuration file
bindsym $mod+Shift+c reload
# bindsym $mod+Shift+p exec waybar

#
# Resizing containers:
#
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    # Ditto, with arrow keys
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

bindsym control+alt+u resize grow width 25px
bindsym control+alt+i resize shrink width 25px

#
# Status Bar:
#
bar {
    swaybar_command waybar
}

include /etc/sway/config.d/*
