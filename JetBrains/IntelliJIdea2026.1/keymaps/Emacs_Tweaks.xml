<keymap version="1" name="FedPro Emacs (VSCode tweaks)" parent="Emacs">
  <action id="$Paste">
    <keyboard-shortcut first-keystroke="shift insert" />
    <keyboard-shortcut first-keystroke="ctrl y" />
  </action>
  <action id="ActivateBookmarksToolWindow">
    <keyboard-shortcut first-keystroke="alt o" />
  </action>
  <action id="ActivateCommitToolWindow">
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="g" />
  </action>
  <action id="ActivateDebugToolWindow">
    <keyboard-shortcut first-keystroke="alt 5" />
  </action>
  <action id="ActivateFavoritesToolWindow">
    <keyboard-shortcut first-keystroke="alt 2" />
  </action>
  <action id="ActivateFindToolWindow">
    <keyboard-shortcut first-keystroke="alt 3" />
  </action>
  <action id="ActivateProblemsViewToolWindow">
    <keyboard-shortcut first-keystroke="shift alt m" />
  </action>
  <action id="ActivateProjectToolWindow">
    <keyboard-shortcut first-keystroke="ctrl 0" />
    <keyboard-shortcut first-keystroke="alt 1" />
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="d" />
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="m" />
  </action>
  <action id="ActivateRunToolWindow">
    <keyboard-shortcut first-keystroke="alt 4" />
  </action>
  <action id="ActivateServicesToolWindow">
    <keyboard-shortcut first-keystroke="alt 8" />
  </action>
  <action id="ActivateStructureToolWindow">
    <keyboard-shortcut first-keystroke="alt 7" />
  </action>
  <action id="ActivateTerminalToolWindow">
    <keyboard-shortcut first-keystroke="alt open_bracket" />
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="j" />
  </action>
  <action id="ActivateVersionControlToolWindow">
    <keyboard-shortcut first-keystroke="alt 9" />
  </action>
  <action id="Back">
    <keyboard-shortcut first-keystroke="alt comma" />
    <keyboard-shortcut first-keystroke="ctrl c" second-keystroke="j" />
  </action>
  <action id="ChooseDebugConfiguration">
    <keyboard-shortcut first-keystroke="f5" />
  </action>
  <action id="ClassNameCompletion" />
  <action id="CloseContent">
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="0" />
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="k" />
  </action>
  <action id="CommentByLineComment">
    <keyboard-shortcut first-keystroke="ctrl semicolon" />
  </action>
  <action id="CompileProject" />
  <action id="CopyElement" />
  <action id="EditorChooseLookupItem">
    <keyboard-shortcut first-keystroke="ctrl j" />
  </action>
  <action id="EditorChooseLookupItemReplace">
    <keyboard-shortcut first-keystroke="ctrl j" />
  </action>
  <action id="EditorDown">
    <keyboard-shortcut first-keystroke="ctrl n" />
  </action>
  <action id="EditorLineStart">
    <keyboard-shortcut first-keystroke="home" />
    <keyboard-shortcut first-keystroke="ctrl a" />
  </action>
  <action id="EditorPageDown">
    <keyboard-shortcut first-keystroke="ctrl v" />
    <keyboard-shortcut first-keystroke="page_down" />
  </action>
  <action id="EditorPageUp">
    <keyboard-shortcut first-keystroke="alt v" />
    <keyboard-shortcut first-keystroke="page_up" />
    <keyboard-shortcut first-keystroke="ctrl z" />
  </action>
  <action id="EditorToggleUseSoftWraps">
    <keyboard-shortcut first-keystroke="alt z" />
  </action>
  <action id="EditorUp">
    <keyboard-shortcut first-keystroke="ctrl p" />
  </action>
  <action id="FindInPath">
    <keyboard-shortcut first-keystroke="ctrl c" second-keystroke="g" />
  </action>
  <action id="FindUsages">
    <keyboard-shortcut first-keystroke="shift alt slash" />
    <keyboard-shortcut first-keystroke="shift alt divide" />
  </action>
  <action id="Forward">
    <keyboard-shortcut first-keystroke="ctrl c" second-keystroke="k" />
  </action>
  <action id="GotoFile">
    <keyboard-shortcut first-keystroke="ctrl c" second-keystroke="f" />
  </action>
  <action id="GotoNextError">
    <keyboard-shortcut first-keystroke="shift alt n" />
    <keyboard-shortcut first-keystroke="f8" />
  </action>
  <action id="GotoPreviousError">
    <keyboard-shortcut first-keystroke="shift alt p" />
    <keyboard-shortcut first-keystroke="shift f8" />
  </action>
  <action id="GotoSymbol">
    <keyboard-shortcut first-keystroke="alt g" second-keystroke="i" />
  </action>
  <action id="HideAllWindows">
    <keyboard-shortcut first-keystroke="shift ctrl f12" />
    <keyboard-shortcut first-keystroke="ctrl alt space" />
  </action>
  <action id="Macro.ScrollDown5">
    <keyboard-shortcut first-keystroke="alt j" />
  </action>
  <action id="Macro.ScrollUp5">
    <keyboard-shortcut first-keystroke="alt k" />
  </action>
  <action id="NextSplitter">
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="o" />
    <keyboard-shortcut first-keystroke="alt semicolon" />
  </action>
  <action id="NextTab">
    <keyboard-shortcut first-keystroke="alt i" />
  </action>
  <action id="PreviousTab">
    <keyboard-shortcut first-keystroke="alt u" />
  </action>
  <action id="QuickChangeScheme">
    <keyboard-shortcut first-keystroke="alt m" />
  </action>
  <action id="ReformatCode">
    <keyboard-shortcut first-keystroke="ctrl i" />
  </action>
  <action id="Resume" />
  <action id="Run">
    <keyboard-shortcut first-keystroke="ctrl f5" />
  </action>
  <action id="SaveAll">
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="ctrl s" />
    <keyboard-shortcut first-keystroke="ctrl w" />
  </action>
  <action id="SelectNextOccurrence" />
  <action id="ShowBookmarks">
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="l" />
  </action>
  <action id="StepInto">
    <keyboard-shortcut first-keystroke="f11" />
  </action>
  <action id="StepOver">
    <keyboard-shortcut first-keystroke="f10" />
  </action>
  <action id="Stop">
    <keyboard-shortcut first-keystroke="shift f5" />
  </action>
  <action id="SwitchHeaderSource" />
  <action id="ToggleBookmark">
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="r" />
  </action>
  <action id="ToggleLineBreakpoint">
    <keyboard-shortcut first-keystroke="f9" />
  </action>
  <action id="ToggleZenMode">
    <keyboard-shortcut first-keystroke="ctrl x" second-keystroke="z" />
  </action>
</keymap>
