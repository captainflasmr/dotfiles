# Sway config used by the greetd greeter (runs as the 'greeter' user).
# Launches nwg-hello; when it exits, sway exits and greetd returns to the greeter.
exec "nwg-hello; swaymsg exit"

bindsym Mod4+shift+e exec swaynag \
	-t warning \
	-m 'What do you want to do?' \
	-b 'Poweroff' 'systemctl poweroff' \
	-b 'Reboot' 'systemctl reboot'

include /etc/sway/config.d/*
