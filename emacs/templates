sh-mode
(qd n "echo \"poop: " q "\"" n)

emacs-lisp-mode
(qd n "(message \"poop: " q "\"\)" n)

ada-mode
(qd n> "Ada.Text_Io.Put_Line \( \"poop: " q "\"\);" n)

c++-mode
(qd n> "std::cout << \"poop: " q "\" << std::endl;" n)

c-mode
(qd n> "fprintf(stderr, \"poop: " q "\"\);" n)
