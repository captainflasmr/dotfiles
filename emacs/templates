(qm (format-time-string "%Y%m%d%H%M%S"))
(qt (format-time-string "%Y%m%d"))
(qp "| ")
(qb "\\")

org-mode

(qi "#+attr_org: :width 300px" n "#+attr_html: :width 100%")
(qe "#+attr_org: :width 300px" n "#+attr_html: :class emacs-img")
