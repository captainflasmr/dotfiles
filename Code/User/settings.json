{
    "redhat.telemetry.enabled": false,
    "java.import.gradle.offline.enabled": true,
    "java.import.maven.offline.enabled": true,
    "editor.cursorStyle": "block",
    "terminal.integrated.fontSize": 15,
    "chat.fontSize": 15,
    "debug.console.fontSize": 15,
    "scm.inputFontSize": 15,
    "java.trace.server": "verbose",
    "task.verboseLogging": true,
    // "editor.fontFamily": "Fira Code, DejaVu Sans Mono, monospace",
    "editor.fontFamily": "Nimbus Mono",
    "editor.fontWeight": "400",
    "editor.fontLigatures": true,
    "editor.inlayHints.enabled": "off",
    "workbench.browser.showInTitleBar": false,
    "workbench.navigationControl.enabled": false,
    "workbench.activityBar.location": "top",
    "editor.lineNumbers": "off",
    "workbench.activityBar.compact": true,
    "explorer.decorations.badges": false,
    "explorer.decorations.colors": false,
    "workbench.tree.indent": 16,
    "workbench.colorTheme": "Dracula Theme",
    "workbench.iconTheme": "vs-minimal",
    "workbench.tree.renderIndentGuides": "always",
    "workbench.editor.highlightModifiedTabs": true,
    // "dired.ask_directory": false,
    "workbench.colorCustomizations": {
        "tab.activeBorderTop": "#ffffff"
        // "tab.activeBorder": "#ffffff"
    },
    "dired.ask_directory": false,
    "explorer.excludeGitIgnore": true,
    "editor.inlineSuggest.showToolbar": "never",
    "multiCommand.commands": [
        {
            "command": "multiCommand.diredOpen",
            "interval": 50,
            "sequence": [
                "extension.dired.open",
                "cursorTop",
                "emacs-mcx.nextLine",
                "emacs-mcx.nextLine",
                "emacs-mcx.nextLine",
                "emacs-mcx.moveEndOfLine"
            ]
        },
        {
            "command": "multiCommand.diredGoUp",
            "interval": 50,
            "sequence": [
                "extension.dired.goUpDir",
                "cursorTop",
                "emacs-mcx.nextLine",
                "emacs-mcx.nextLine",
                "emacs-mcx.nextLine",
                "emacs-mcx.moveEndOfLine"
            ]
        }
    ],
    "window.enableMenuBarMnemonics": false,
    "editor.quickSuggestions": {
        "other": "off",
        "comments": "off",
        "strings": "off"
    },
    "editor.suggestOnTriggerCharacters": false,
    "editor.wordBasedSuggestions": "off",
    "editor.parameterHints.enabled": false,
    "window.commandCenter": false,
    "editor.minimap.enabled": false,
    "git.openRepositoryInParentFolders": "never"
}
